# VPS deployment: copy to /run/news-harness/news_harness.env
# Permissions: chmod 600, chown news-harness:news-harness
NEWS_HARNESS_X_COOKIE_FILE=/run/news-harness/secrets/x-list-reader-cookie
NEWS_HARNESS_REDDIT_COOKIE_FILE=/run/news-harness/secrets/reddit-reader-cookie
DEEPSEEK_API_KEY_FILE=/run/news-harness/secrets/deepseek-api-key
